import tkinter as tk
from tkinter import ttk, messagebox


# -------- Dijkstra --------
def dijkstra(graph, start, end, cities):
    n = len(graph)
    dist = [float("inf")] * n
    visited = [False] * n
    parent = [-1] * n

    dist[start] = 0

    for _ in range(n):
        min_dist = float("inf")
        u = -1
        for i in range(n):
            if not visited[i] and dist[i] < min_dist:
                min_dist = dist[i]
                u = i

        visited[u] = True

        for v in range(n):
            if graph[u][v] != 0 and not visited[v]:
                if dist[u] + graph[u][v] < dist[v]:
                    dist[v] = dist[u] + graph[u][v]
                    parent[v] = u

    path = []
    cur = end
    while cur != -1:
        path.append(cities[cur])
        cur = parent[cur]

    path.reverse()
    return path, dist[end]


# -------- Load Cities --------
def load_cities():
    try:
        global cities
        cities = [c.strip() for c in entry_cities.get().split(",")]

        combo_source["values"] = cities
        combo_dest["values"] = cities

        messagebox.showinfo("Success", "Cities Loaded Successfully!")
    except:
        messagebox.showerror("Error", "Invalid city input!")


# -------- Calculate --------
def calculate():
    try:
        matrix_input = text_matrix.get("1.0", tk.END).strip().split("\n")
        graph = [list(map(int, row.split())) for row in matrix_input]

        src = cities.index(combo_source.get())
        dest = cities.index(combo_dest.get())

        path, distance = dijkstra(graph, src, dest, cities)

        result = f"""
================ ROUTE RESULT ================

Source        : {cities[src]}
Destination   : {cities[dest]}

Path          : {" -> ".join(path)}
Distance      : {distance} km
Stops         : {len(path)}

=============================================
"""

        output_box.config(state="normal")
        output_box.delete("1.0", tk.END)
        output_box.insert(tk.END, result)
        output_box.config(state="disabled")

    except:
        messagebox.showerror("Error", "Please check all inputs!")


