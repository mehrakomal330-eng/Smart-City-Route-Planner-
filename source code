# Button
tk.Button(
    root,
    text="Find Shortest Route",
    font=("Arial", 14, "bold"),
    bg="#2196F3",
    fg="white",
    padx=20,
    pady=5,
    command=calculate,
).pack(pady=20)

# Output box
output_box = tk.Text(
    root, height=15, width=80, bg="#121212", fg="#00FFAA", font=("Courier", 12)
)
